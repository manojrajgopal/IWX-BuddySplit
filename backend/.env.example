# ──────────────── App
NODE_ENV=development
APP_NAME=IWX-BuddySplit
PORT=4000
PUBLIC_API_URL=http://localhost:4000
PUBLIC_WEB_URL=http://localhost:3000
LOG_LEVEL=info

# ──────────────── Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=buddysplit
DB_PASSWORD=buddysplit
DB_DATABASE=buddysplit
DB_SSL=false
DB_POOL_MAX=20

# ──────────────── Auth
JWT_ACCESS_SECRET=please-change-me-access-secret-32chars-min
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=please-change-me-refresh-secret-32chars-min
JWT_REFRESH_TTL=30d
OTP_HMAC_SECRET=please-change-me-otp-secret-32chars
OTP_TTL_SECONDS=600
OTP_LENGTH=6
PASSWORD_PEPPER=please-change-me-pepper

# ──────────────── Mail (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="IWX-BuddySplit <no-reply@buddysplit.local>"

# ──────────────── Realtime / CORS
CORS_ORIGINS=http://localhost:3000
SOCKET_PATH=/realtime

# ──────────────── Cache
LRU_MAX_ITEMS=5000
LRU_TTL_MS=60000

# ──────────────── Revalidation (Next.js)
REVALIDATION_SECRET=please-change-me-revalidation-secret
