# ──────────────── App
NODE_ENV=production
APP_NAME=IWX BuddySplit
PORT=4000
PUBLIC_API_URL=https://api.example.com
PUBLIC_WEB_URL=https://app.example.com
LOG_LEVEL=info

# ──────────────── Database (Amazon RDS PostgreSQL)
DB_HOST=your-rds-endpoint.xxxxx.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_USERNAME=buddysplit
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_DATABASE=buddysplit
DB_SSL=true
DB_POOL_MAX=20

# ──────────────── Auth secrets
# Generate each with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_64_HEX_CHARS
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=CHANGE_ME_64_HEX_CHARS
JWT_REFRESH_TTL=30d
OTP_HMAC_SECRET=CHANGE_ME_64_HEX_CHARS
OTP_TTL_SECONDS=600
OTP_LENGTH=6
PASSWORD_PEPPER=CHANGE_ME_LONG_RANDOM
ENC_SECRET=CHANGE_ME_64_HEX_CHARS

# ──────────────── Realtime / CORS
CORS_ORIGINS=https://app.example.com
SOCKET_PATH=/realtime

# ──────────────── Cache
LRU_MAX_ITEMS=5000
LRU_TTL_MS=60000

# ──────────────── Next.js revalidation
REVALIDATION_SECRET=CHANGE_ME_LONG_RANDOM

# ──────────────── Google OAuth (optional)
GOOGLE_OAUTH_CLIENT_ID=
